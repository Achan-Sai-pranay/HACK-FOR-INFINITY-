{
  "manifest_version": 3,
  "name": "Neuro Reader",
  "description": "A neuroinclusive reading assistant for ADHD and dyslexia.",
  "version": "1.0",

  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/logo.jpeg"
  },

  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["styles/reader.css"]
    }
  ],

  "host_permissions": [
  "<all_urls>",
  "https://api.groq.com/*"
],

  "background": {
    "service_worker": "background.js"
  }

}